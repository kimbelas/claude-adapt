{
  "name": "claude-adapt",
  "version": "0.1.0",
  "description": "Claude Code configuration tool — score your codebase readiness, generate optimized CLAUDE.md and .claude/ config, install skill packs, and keep config evolving across sessions.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "claude-adapt": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "skills"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean",
    "dev": "tsup src/cli.ts --format esm --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/ --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "score": "tsx src/cli.ts score .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "claude-md",
    "anthropic",
    "ai",
    "ai-tools",
    "developer-tools",
    "code-quality",
    "static-analysis",
    "configuration",
    "cli",
    "claude-code-setup",
    "claude-code-config",
    "CLAUDE.md",
    "ai-assisted-development",
    "code-readiness",
    "codebase-scoring",
    "mcp",
    "skill-packs"
  ],
  "author": "Kim Belas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kimbelas/claude-adapt.git"
  },
  "homepage": "https://github.com/kimbelas/claude-adapt#readme",
  "bugs": {
    "url": "https://github.com/kimbelas/claude-adapt/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "handlebars": "^4.7.8",
    "ora": "^8.1.0",
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.5.0",
    "@types/semver": "^7.5.8",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^2.1.0"
  }
}
