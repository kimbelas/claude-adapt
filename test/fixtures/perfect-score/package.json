{
  "name": "perfect-score",
  "version": "1.3.0",
  "description": "A robust, production-ready TypeScript library for user management and utilities",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src __tests__ --ext .ts",
    "lint:fix": "eslint src __tests__ --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts' '__tests__/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": ["typescript", "utilities", "user-management"],
  "author": "Perfect Score Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "zod": "^3.23.0",
    "uuid": "^9.0.1",
    "date-fns": "^3.6.0",
    "lodash-es": "^4.17.21",
    "pino": "^9.1.0",
    "ky": "^1.3.0",
    "nanoid": "^5.0.7",
    "ms": "^2.1.3",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.2.5",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0",
    "vite": "^5.2.0"
  }
}
